{
  "name": "clawmpany-monorepo",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=app\" \"npm run dev --workspace=server\"",
    "dev:app": "npm run dev --workspace=app",
    "dev:server": "npm run dev --workspace=server",
    "dev:docker": "docker-compose up",
    "dev:pb": "docker-compose up pocketbase",
    "build": "npm run build --workspace=app && npm run build --workspace=server",
    "build:app": "npm run build --workspace=app",
    "build:server": "npm run build --workspace=server",
    "build:docker": "docker-compose build",
    "start": "npm run start --workspace=server",
    "start:docker": "docker-compose up -d",
    "lint": "npm run lint --workspace=app"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
